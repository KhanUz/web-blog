{
    "name":  "web-blog",
    "version":  "1.0.0",
    "private":  true,
    "description":  "Workspace for a web blog frontend and backend",
    "workspaces":  [
                       "apps/frontend",
                       "apps/backend"
                   ],
    "scripts":  {
                    "dev:frontend":  "npm run dev --workspace frontend",
                    "dev:backend":  "npm run dev --workspace backend",
                    "dev:all":  "bash ./scripts/dev-launch.sh",
                    "build":  "npm run build --workspace frontend \u0026\u0026 npm run build --workspace backend",
                    "check":  "npm run check --workspace frontend \u0026\u0026 npm run check --workspace backend"
                },
    "engines":  {
                    "node":  "\u003e=20.0.0"
                },
    "dependencies":  {
                         "marked":  "^17.0.5"
                     }
}
